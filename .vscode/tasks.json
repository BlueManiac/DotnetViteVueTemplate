{
    "version": "2.0.0",
    "options": {
        "env": {}
    },
    "tasks": [
        {
            "label": "build backend",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/src/Web/Web.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/src/Web/Web.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/p:PublishProfile=${workspaceFolder}/src/Web/Properties/PublishProfiles/FolderProfile.pubxml",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch backend",
            "command": "dotnet",
            "type": "process",
            "isBackground": true,
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}\\src\\Web\\Web.csproj",
                "--launch-profile",
                "Web"
            ],
            "problemMatcher": {
                "base": "$msCompile",
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Building",
                    "endsPattern": "Application started"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "group": "watch",
                "close": true
            }
        },
        {
            "label": "watch frontend",
            "type": "shell",
            "isBackground": true,
            "command": "powershell",
            "args": [
                "${workspaceFolder}/src/Web/Properties/npmrun.ps1"
            ],
            "problemMatcher": [
                {
                    "pattern": {
                        "regexp": "^$"
                    },
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": "VITE.*ready",
                        "endsPattern": "Local:.*https?://localhost"
                    }
                },
                {
                    "owner": "vite-runtime",
                    "source": "vite-runtime",
                    "fileLocation": "absolute",
                    "severity": "error",
                    "pattern": [
                        {
                            "regexp": "^\\S+\\s+\\[vite\\]\\s+Client error:\\s+(.+)$",
                            "message": 1
                        },
                        {
                            "regexp": "^\\s+Plugin:\\s+vite-runtime-error-plugin$"
                        },
                        {
                            "regexp": "^\\s+File:\\s+(.+):(\\d+):(\\d+)$",
                            "file": 1,
                            "line": 2,
                            "column": 3
                        }
                    ],
                    "background": {
                        "activeOnStart": false,
                        "beginsPattern": "\\[vite\\].*page reload|\\[vite\\].*hmr",
                        "endsPattern": "Client error reported\\.|Client loaded successfully\\."
                    }
                }
            ],
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "group": "watch",
                "close": true
            }
        },
        {
            "label": "watch",
            "problemMatcher": [],
            "dependsOn": [
                "watch frontend",
                "watch backend"
            ]
        },
        {
            "label": "update",
            "problemMatcher": [],
            "dependsOn": [
                "update backend",
                "update frontend"
            ]
        },
        {
            "label": "update backend",
            "command": "dotnet",
            "type": "process",
            "args": [
                "outdated",
                "${workspaceFolder}/src/Web/Web.csproj"
            ],
            "problemMatcher": []
        },
        {
            "label": "update frontend",
            "type": "shell",
            "command": "npm",
            "args": [
                "run",
                "update"
            ],
            "options": {
                "cwd": "${workspaceFolder}/src/Web"
            },
            "problemMatcher": []
        },
        {
            "label": "stop backend",
            "type": "process",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-Command",
                "$proc = Get-CimInstance Win32_Process | Where-Object { $_.CommandLine -like \"*dotnet.exe* watch run --project ${workspaceFolder}\\src\\Web\\Web.csproj\" }; if ($proc) { Stop-Process -Id $proc.ProcessId -Force }"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "close": true
            }
        },
        {
            "label": "restart backend",
            "problemMatcher": [],
            "dependsOn": [
                "stop backend",
                "watch backend"
            ],
            "dependsOrder": "sequence"
        }
    ]
}